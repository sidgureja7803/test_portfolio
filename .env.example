# EmailJS Configuration
# Get these from https://www.emailjs.com/

# 1. Service ID - From "Email Services" section
REACT_APP_EMAILJS_SERVICE_ID=service_xxxxxxx

# 2. Template ID - From "Email Templates" section  
REACT_APP_EMAILJS_SERVICE_ID=template_xxxxxxx

# 3. Public Key - From "Account" > "API Keys"
REACT_APP_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxx

# Note: After adding these values, restart your dev server
# Never commit the actual .env file to GitHub!
